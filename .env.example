# ╔══════════════════════════════════════════════╗
# ║    ChemML Purple Agent — Configuration       ║
# ╚══════════════════════════════════════════════╝

# LLM Configuration
# Use any LiteLLM-supported provider: https://docs.litellm.ai/docs/providers
# Recommended: gpt-4o (best for code generation)
# Alternatives:
#   anthropic/claude-sonnet-4-20250514
#   google/gemini-2.0-flash
#   openrouter/openai/gpt-4o
LLM_MODEL=openai/gpt-4o

# API Keys (set the one matching your provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# Agent settings
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192

# Code execution timeout (seconds) — max time for ML training
CODE_TIMEOUT=900
